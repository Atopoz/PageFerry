{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Select source documents from the PageFerry main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "dialog:allow-open",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "http://*" }, { "url": "https://*" }]
    }
  ]
}
