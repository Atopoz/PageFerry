{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "windows-window-controls",
  "description": "允许 PageFerry 主窗口调用三个 Windows 自绘标题栏控制命令",
  "windows": ["main"],
  "platforms": ["windows"],
  "permissions": [
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close"
  ]
}
